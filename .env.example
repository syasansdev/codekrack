# =============================================================================
# CodeKrack — FRONTEND environment (Vite)
# Copy to `.env` and fill in.
#
# ⚠️ Every VITE_* var is bundled into the public client JS — anyone can read it
#    in devtools. Only public values belong here. The Supabase service_role /
#    Secret key must NEVER appear in this file.
# =============================================================================

# ---- SUPABASE (authentication only) -----------------------------------------
# Dashboard -> Project Settings -> API
#
# The browser uses Supabase ONLY to sign in and hold the session. It never
# queries the database: RLS denies the anon key on every table, deliberately.
# All data goes through the Express API below, which enforces institution
# scoping server-side.
#
# New projects label this the "Publishable key" rather than "anon" — same thing.
# Paste whichever your dashboard shows (`eyJ...` or `sb_publishable_...`).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- BACKEND API ------------------------------------------------------------
# The Express server. All application data flows through this.
# In production, point it at your deployed backend (Render/Railway/Fly).
VITE_API_URL=http://localhost:5001

# ---- GEMINI (optional) ------------------------------------------------------
# Used by the "Add Student" AI Excel import (AdminUserCreation.jsx). Bundled into
# client JS, so restrict the key in Google AI Studio — or leave it blank to
# disable the AI import and fall back to plain Excel parsing.
# ⚠️ SEC-05: this ships in the public bundle. Proxy it behind the API when you can.
VITE_GEMINI_API_KEY=

# =============================================================================
# REMOVED — do not re-add:
#
#   VITE_FIREBASE_*      Firebase is gone. Auth is Supabase; data is Postgres.
#   VITE_DEV_BYPASS      Aliased the Firebase SDK to in-memory mocks in
#   VITE_DEV_ROLE        src/mocks/. Both the mocks and the aliases are deleted.
#                        To develop against throwaway data, point VITE_SUPABASE_*
#                        at a scratch Supabase project — that exercises the real
#                        code paths instead of an imitation of them.
#   VITE_GITHUB_TOKEN    Fed the browser scrapers, which are deleted. Scraping is
#                        server-side now (backend GH_API_TOKEN + the GitHub
#                        Action), so the browser needs no GitHub credentials and
#                        no CORS proxies.
# =============================================================================
